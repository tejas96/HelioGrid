# ─── Google Maps (CLIENT-side: Maps JS loader + Static tiles) ───────────────
# This key ships in the browser bundle by design — restrict it in the Google
# Cloud console to: Maps JavaScript API + Static Maps API, plus HTTP-referrer
# restrictions for your domains. Do NOT enable the Solar API on this key.
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here

# ─── Google Solar API (SERVER-side only — paid endpoints) ────────────────────
# Used exclusively by the /api/solar/* proxy routes (buildingInsights,
# dataLayers, geoTiff relay). Restrict this key to the Solar API only; it is
# never exposed to the browser. If unset, the proxy falls back to the public
# Maps key above (dev convenience only — split the keys in production).
GOOGLE_SOLAR_API_KEY=

# ─── Gemini (SERVER-side only, optional) ─────────────────────────────────────
# Enables the AI photo/drone roof-detection path (/api/gemini). Absent = the
# feature reports 'unconfigured' and the app degrades gracefully.
GEMINI_API_KEY=
